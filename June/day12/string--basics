#include <iostream>
#include <string>
using namespace std;

int main()
{
    string firstName = "Elian";
    string lastName = "Solari";
    
    string fullName = firstName + " " + lastName;
    cout << "Full Name: " << fullName << endl;
    
    cout << "Character Count: " << fullName.length() << endl;
    
    cout << "The very first letter: " << fullName[0] << endl;
    
    fullName[0] = 'A';
    cout << "Altered Name: " << fullName << endl;

    return 0;
}
